{
  "name": "steam-girl-character-website",
  "version": "1.0.0",
  "description": "Steam Girl - Pixar-inspired character portal showcasing the journey of a magical being who bridges fire and water elements in Element City",
  "main": "index.html",
  "keywords": [
    "ai-art",
    "character-design",
    "pixar-style",
    "steam-girl",
    "element-city",
    "interactive-website",
    "css-animations",
    "particle-effects",
    "responsive-design"
  ],
  "author": "Your Name",
  "license": "MIT",
  "homepage": ".",
  "repository": {
    "type": "git",
    "url": "."
  },
  "scripts": {
    "start": "npx serve . -p 3000",
    "dev": "npx serve . -p 3000 --live",
    "build": "echo 'This is a static website - no build needed'",
    "preview": "npx serve . -p 8080",
    "lint": "npx eslint script.js",
    "format": "npx prettier --write *.html *.css *.js *.md",
    "validate": "npx html-validate *.html",
    "lighthouse": "npx lighthouse http://localhost:3000 --output=html --output-path=lighthouse-report.html"
  },
  "devDependencies": {
    "serve": "^14.2.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "html-validate": "^8.9.1",
    "lighthouse": "^11.4.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "files": [
    "index.html",
    "profile.html",
    "growth.html",
    "styles.css",
    "advanced-effects.css",
    "script.js",
    "*.jpg",
    "*.jpeg",
    "*.png",
    "*.md"
  ]
} 